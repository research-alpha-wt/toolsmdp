{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--no-header"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Debug Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v", "--no-header"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
